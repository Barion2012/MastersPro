@model LoginWith2faModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Двухфакторная аутентификация";
}

<div class="request__form-content">
    <h3 class="request__form-header">Для завершения входа<br />введите код аутентификатора</h3>
        <form method="post" asp-route-returnUrl="@ViewBag.ReturnUrl">
            <input asp-for="@Model.RememberMe" type="hidden" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
            <input asp-for="@Model.TwoFactorCode" class="form-control" autocomplete="off" />
                <span asp-validation-for="@Model.TwoFactorCode" class="text-danger"></span>
            </div>
        <div class="form-group form-check">
                <div class="checkbox">
                    <label asp-for="@Model.RememberMachine" class="form-check-label">
                        <input asp-for="@Model.RememberMachine" class="form-check-input"/>
                        @Html.DisplayNameFor(m => m.RememberMachine)
                    </label>
                </div>
            </div>
        <div class="form-group">
            <button type="submit" class="btn btn-primary">Вход</button>
</div>
<p>
    	У вас нет доступа к вашему устройству аутентификации? Используйте
	<a id="recovery-code-login" asp-action="LoginWithRecoveryCode" asp-controller="Account" asp-route-returnUrl="@ViewBag.ReturnUrl">код восстановления для входа</a>.
</p>

    </form>
</div>
