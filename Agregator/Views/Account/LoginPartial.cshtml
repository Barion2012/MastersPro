@model MainLoginModel

@using (Html.BeginForm("LoginPhonePartial", "Account", FormMethod.Post, new { id = "login-form", @class = "form", role = "form", action = "javascript:void(null);" }))
{
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <input asp-for="loginModel.Email" class="form-control" type="email" placeholder="e-mail">
        <span asp-validation-for="loginModel.Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input asp-for="loginModel.Password" class="form-control type="password" placeholder="пароль">
        <span asp-validation-for="loginModel.Password" class="text-danger"></span>
    </div>

    <input type="hidden" asp-for="RememberMe" />

    <button class="btn btn-primary mt-1" type="submit">Войти</button>

    <div class="mt-1"><a asp-action="ForgotPassword" asp-controller="Account">забыли пароль?</a></div>

}

<script>
    $("form#login-form").on('submit', f => fetch('/Account/LoginPartial', {
            method: 'post'
            , headers: { 'Accept': 'text/html' }
        , body: new FormData(f.target)
    })
        .then(r =>  r.text())
        .then(r => {
            if (r.startsWith("/"))
                location.href = r
            else
                $('#tab-login-form').html(r)
        }))
</script>