@model ChangePasswordModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Изменение пароля";
}

<div class="request__form-content">
    <h3 class="request__form-header">Задайте новый пароль</h3>
    <form method="post" id="change-password-form">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="form-group">
            <input asp-for="@Model.OldPassword" class="form-control" type="password" autocomplete="off" placeholder="Текущий пароль" />
            <span asp-validation-for="@Model.OldPassword" class="text-danger"></span>
        </div>
        <div class="form-group">
            <input asp-for="@Model.NewPassword" class="form-control"  type="password" autocomplete="off" placeholder="Новый пароль" />
            <span asp-validation-for="@Model.NewPassword" class="text-danger"></span>
        </div>
        <div class="form-group">
            <input asp-for="@Model.ConfirmPassword" class="form-control"  type="password" autocomplete="off"  placeholder="Потверждение пароля" />
            <span asp-validation-for="@Model.ConfirmPassword" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary" >OK</button>

    </form>
</div>
