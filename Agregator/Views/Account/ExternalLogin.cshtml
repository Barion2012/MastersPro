@model MainLoginModel
@{
    ViewData["Title"] = "Регистрация";
}

<h1>@ViewData["Title"]</h1>
<h4 id="external-login-title">Привязка к учетной записи @Model.ProviderName.</h4>
<hr />

<p id="external-login-description" class="text-info">
    Вы успешно прошли проверку подлинности с помощью <strong>@Model.ProviderName </strong>.
    Пожалуйста, введите адрес электронной почты для этого сайта ниже и нажмите кнопку Регистрация, чтобы завершить
    вход в систему.
</p>

<div class="row">
    <div class="col-md-4">
        <form asp-action="ExternalLoginConfirmation" asp-controller="Account" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="externalLogin.Email"></label>
                <input asp-for="externalLogin.Email" class="form-control" />
                <span asp-validation-for="externalLogin.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Регистрация</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
