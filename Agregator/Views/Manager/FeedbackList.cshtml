@using (Html.DevExtreme().NamedTemplate("BanksView"))
{@(Html.DevExtreme().DataGrid()
        .ID("BanksViewID")
        .DataSource(new JS(@"component.getDataSource()"))
        .Columns(columns => {
            columns.Add().DataField("Id").Visible(false);
            columns.Add().DataField("Name").Caption("Банк");
            columns.Add().DataField("City").Caption("");
            columns.Add().DataField("BIK").Caption("БИК");
            columns.Add().DataField("CorAccount").Caption("Корсчет");
        })
        .HoverStateEnabled(true)
        .Paging(p => p.PageSize(10))
        .FilterRow(f => f.Visible(true))
        .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
        .Height(250)
        .Selection(s => s.Mode(SelectionMode.Single))
        .SelectedRowKeys(new JS(@"[component.option(""value"")]"))
        .OnSelectionChanged(@<text>
            function(selectedItems) {
                var keys = selectedItems.selectedRowKeys;
                component.option("value", keys);
            }
        </text>)
    )}

</div>
<script>

  //  var form;


    function gridBox_valueChanged(e) {
         var $dataGrid = $("#BanksViewID");

        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
        }
    }
    function gridBox_displayExpr(item) {
        return item.Name+' в г. '+item.City;
    }
    function saveField(e)
    {
        $.ajax({
            url: '@Url.Action("Put", "Recipients")'
            , type: "PUT"
            , data: {
                key: e.component.option("formData").appUserId,
                values: '{"'+e.dataField+'":"'+ e.value+'"}'
            }
            , success: (res) => console.log("res=>"+res)
            , error: (err) => console.log("err=> '" + e.value+"'")
        })
    }

    function expandRow(e)
    {
        var row = null;
        var ds = e.component.getDataSource().items();
        for (var x in ds) {
            var xe = ds[x];
            if (xe.RowId == e.key) {
                row = xe;
                break;
            }
        }

        $.ajax({

            url: '@Url.Action("GetRecipient", "Recipients")'
            , type: "GET"
            , data: {
                user_id: row.UserId,
            }
            , success: (res) => {
                var form = $('#feedback-detal-' + res.appUserId).dxForm('instance');

                form.option('formData', row.Recipient = res);
                form.option("onFieldDataChanged", saveField);

              //  form.itemOption("INTPASS", "visible", false);
                //   form.refrash();
             //   console.log(form.items[1]);
            }
            , error: (err) => console.log("err=>"+err)
        })
    }

    function newContract(e) {
        //console.log(e.validationGroup.group.option("formData").Id+";"+$('textarea')[1].value)
        $.ajax({
            url: '@Url.Action("Post", "Documents")'
            , type: "POST"
            , data: JSON.stringify(
                {
                    Id: e.validationGroup.group.option("formData").appUserId,
                    Text: $('textarea[name="dog-' + e.validationGroup.group.option("formData").appUserId + '"]').val()
                })
            , success: (res) => DevExpress.ui.notify({
                message: "Сформирован новый договор № " + res.number,
                position: {
                    my: "center top",
                    at: "center top"
                }
            }, "success", 3000)

            , error: (err) => {
                console.log(err); DevExpress.ui.notify({
                    message: "Договор не сформирован:" + err.responseJSON.Errors[0].ErrorMessage,
                    position: {
                        my: "center top",
                        at: "center top"
                    }
                }, "error", 5000)
            }
        })
    }
</script>







