@{ ViewData["Title"] = "Реестр откликов"; }

<h2>@ViewData["Title"]</h2>

<div>
@(Html.DevExtreme().DataGrid<Feedback>().ID("feedback-dataGrid")
                                        .DataSource(ds => ds.Mvc()
                                            .Controller("Feedbacks")
                                            .LoadAction("Get")
                                            .UpdateAction("Put")


                                            .Key("RowId")
                                        //            .OnLoaded(@<text >(d)=>{ $("#feedback-dataGrid").dxDataGrid("instance").option("data",d) } </text>)
                                        )
                                        .RemoteOperations(true)
                                        //          .OnSaving(@<text>(c)=>{console.log($("#devextreme0").dxDataGrid("instance").option("data")); console.log(c.changes[0])}</text>)
                                        .Columns(columns =>
                                        {

                                            columns.AddFor(m => m.RowId).Visible(false);
                                            columns.AddFor(m => m.Status).Caption("Статус")
                                                .Width(200)
                                                .Lookup(lookup => lookup

                                                    .DataSource(ds => ds.Mvc().Controller("Feedbacks").LoadAction("FeedBackStatusLookup").Key("Value"))
                                                 .ValueExpr("Value")
                                                 .DisplayExpr("Text")
                                                );

                                            //.Buttons();

                                            columns.AddFor(m => m.User.Email).Caption("Пользователь").AllowEditing(false);

                                            columns.AddFor(m => m.VacancyNavigation.PositionNavigation.Name).Caption("Вакансия").AllowEditing(false);
                                            columns.AddFor(m => m.Created).Caption("Запрос").AllowEditing(false);
                                            columns.AddFor(m => m.Updated).Caption("Ответ").AllowEditing(false);
                                            columns.Add().Caption("ДатаДоговора").AllowEditing(false);

                                        })
                                        .Editing(e => e
                                            .AllowUpdating(true)
                                            .Mode(GridEditMode.Cell)

                                        ).MasterDetail(m => m
                                            .Enabled(true)
                                            .Template(new TemplateName("feedback-detals"))

                                            ).OnRowExpanding("expandRow")
)

