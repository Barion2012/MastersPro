@{
    ViewData["Title"] = "Справочник работ";
}

<h2>@ViewData["Title"]</h2>

@(Html.DevExtreme().DataGrid<Work>()
    .DataSource(ds => ds.Mvc()
        .Controller("Works")
        .LoadAction("Get")
        .InsertAction("Post")
        .UpdateAction("Put")
        .DeleteAction("Delete")
        .Key("RowId")
    )
    .RemoteOperations(true)
    .Columns(columns => {

        columns.AddFor(m => m.RowId);

        columns.AddFor(m => m.Status);

        columns.AddFor(m => m.Name);

        columns.AddFor(m => m.Created);

        columns.AddFor(m => m.Updated);

        columns.AddFor(m => m.ParentId);
    })
    .Editing(e => e
        .AllowAdding(true)
        .AllowUpdating(true)
        .AllowDeleting(true)
    )
)
